# Neon Postgres connection string (auto-populated by the Vercel Neon integration).
DATABASE_URL=postgres://user:password@ep-xxx.neon.tech/forge_auto_parts?sslmode=require

# imgbb API key (https://api.imgbb.com/) — used server-side to upload part images.
IMGBB_API_KEY=changeme

# Secret used to sign the admin session JWT. Generate with: openssl rand -base64 32
SESSION_JWT_SECRET=changeme

# WhatsApp business number in international format, digits only (no +, no leading 0).
NEXT_PUBLIC_WHATSAPP_NUMBER=254700000000
