# =============================================================================
# ForgeVault — environment template
#
# This file is COMMITTED. It documents every variable the app needs and must
# contain PLACEHOLDERS ONLY — never a real key, token, or URL.
#
# To use it:
#     cp .env.example .env      # .env is gitignored; put the real values there
#
# For production, set the same variables in:
#     Vercel → Project → Settings → Environment Variables
#
# Only VITE_-prefixed variables are exposed to the browser. Everything below is
# server-side. Never add a VITE_ prefix to a secret — that bundles it into the
# public JavaScript for anyone to read.
# =============================================================================


# --- Database (Supabase) -----------------------------------------------------
# The BARE project URL — no path, no trailing slash:
#     https://<project-ref>.supabase.co          correct
#     https://<project-ref>.supabase.co/rest/v1/ WRONG — every query will 404
# The client appends /rest/v1 itself. (Supabase → Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# SERVICE ROLE key — bypasses Row Level Security, reads and writes everything.
# Server-side only. If it ever leaks, rotate it immediately in the Supabase
# dashboard (Settings → API → Rotate).
# (Settings → API → service_role secret. NOT the anon/public key.)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# --- Site --------------------------------------------------------------------
# Public origin, used to build links in emails and payment callbacks.
# On Vercel you may leave this blank — VERCEL_URL is used automatically.
SITE_URL=http://localhost:5173


# --- Email (Brevo) -----------------------------------------------------------
# REQUIRED. Checkout and admin sign-in both rely on emailed one-time codes, so
# without a working key no customer can order and no admin can log in.
# https://app.brevo.com/settings/keys/api — the sending domain (or sender
# address) must be verified in Brevo first, or mail is rejected.
BREVO_API_KEY=xkeysib-your-api-key

# Must be a sender you verified with Brevo.
EMAIL_FROM=ForgeVault <orders@example.com>
EMAIL_REPLY_TO=support@example.com

# Full email address. Receives new-order alerts, refund requests, and
# contact-form messages.
ADMIN_INBOX=support@example.com


# --- Payments: Paystack (cards) ----------------------------------------------
# https://dashboard.paystack.com/#/settings/developers
# Test keys start with sk_test_, live keys with sk_live_.
PAYSTACK_SECRET_KEY=sk_test_your_secret_key

# REQUIRED SEPARATE STEP: in the same dashboard, register the webhook URL
#     https://YOUR-DOMAIN/api/webhooks/paystack
# Orders are confirmed by that webhook, NOT by the browser redirect back from
# Paystack (which a customer can forge). Without it, customers are charged and
# their orders are never confirmed.


# --- Payments: Crypto (not implemented) --------------------------------------
# Leave commented out. The adapter is a deliberate stub — crypto has different
# settlement, under/overpayment and refund semantics that need real decisions
# first. See api/_lib/payments/crypto.js. Setting this without implementing the
# adapter will break checkout.
# CRYPTO_PROVIDER=


# --- Pricing -----------------------------------------------------------------
CURRENCY=USD

# Flat shipping in CENTS (1500 = $15.00)
SHIPPING_FLAT_CENTS=1500

# Free shipping above this subtotal, in CENTS (50000 = $500.00). 0 disables it.
FREE_SHIPPING_THRESHOLD_CENTS=50000

# Tax as a decimal (0.21 = 21% VAT). 0 disables tax.
TAX_RATE=0


# --- Cron --------------------------------------------------------------------
# Bearer token protecting /api/cron/lifecycle (abandoned carts, review requests).
# Generate one with:  openssl rand -base64 32
# Vercel sends it to scheduled functions automatically.
# Without it the endpoint refuses to run — correct, since an open endpoint that
# sends email is an open relay.
CRON_SECRET=generate-with-openssl-rand-base64-32


# --- Direct Postgres connection (migrations only) ----------------------------
# Needed ONLY to apply db/schema.sql (DDL cannot go through the REST API).
# The running app never uses this. Do NOT set it in Vercel.
# Supabase → Settings → Database → Connection string → URI (session pooler, 5432)
DATABASE_URL=postgresql://postgres.your-ref:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres


# --- Image storage (Supabase Storage) ----------------------------------------
# Product photos, hero slides and category tiles are uploaded from the admin
# panel into this bucket. It rides on the SUPABASE_* credentials above — there
# is no extra key to configure.
#
# Create it once with:  npm run setup-storage
SUPABASE_STORAGE_BUCKET=media
